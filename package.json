{
  "name": "json-tapose",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "main": "desktop-dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:extension": "vite build --config vite.extension.config.ts",
    "build:desktop-main": "tsc -p tsconfig.electron.json",
    "desktop:dev": "pnpm build:desktop-main && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:8173 electron .",
    "desktop:pack": "pnpm build && pnpm build:desktop-main && electron-builder --dir --config electron-builder.yml",
    "desktop:dist": "pnpm build && pnpm build:desktop-main && electron-builder --mac --win --config electron-builder.yml",
    "lint": "eslint .",
    "test": "node --test --experimental-strip-types src/utils/jsonUtils.test.ts src/extension/clipboard.test.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.7",
    "daisyui": "^5.0.35",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "tailwindcss": "^4.1.7",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.4.1",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  },
  "packageManager": "pnpm@9.12.1+sha512.e5a7e52a4183a02d5931057f7a0dbff9d5e9ce3161e33fa68ae392125b79282a8a8a470a51dfc8a0ed86221442eb2fb57019b0990ed24fab519bf0e1bc5ccfc4"
}
