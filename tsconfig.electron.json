{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "desktop-dist",
    "rootDir": "electron",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.electron.tsbuildinfo",
    "types": ["node"]
  },
  "include": ["electron/**/*.ts"]
}
